    "## 12. Write a function to check if a given password is strong (at least 8 characters, at least one lower case, at least one upper case, at least one number and at least one special character). It should output True if strong and False if not."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 38,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "False\n",
      "False\n",
      "False\n",
      "False\n",
      "False\n",
      "True\n"
     ]
    }
   ],
   "source": [
    "def check_pass(password):\n",
    "#your code here\n",
    "    if len(password) < 8:\n",
    "        return False\n",
    "\n",
    "    has_lower = False\n",
    "    has_upper = False\n",
    "    has_number = False\n",
    "    has_special = False\n",
    "    special_chars = \"!@#$%^&*()_+-=[]{}|;:',.<>?/`~\"\n",
    "\n",
    "    for char in password:\n",
    "        if char.islower():\n",
    "            has_lower = True\n",
    "        elif char.isupper():\n",
    "            has_upper = True\n",
    "        elif char.isdigit():\n",
    "            has_number = True\n",
    "        elif char in special_chars:\n",
    "            has_special = True\n",
    "\n",
    "    return has_lower and has_upper and has_number and has_special\n",
    "\n",
    "\n",
    "print(check_pass(\"weak\"))               # False\n",
    "print(check_pass(\"alllowercase1!\"))     # False\n",
    "print(check_pass(\"ALLUPPERCASE1!\"))     # False\n",
    "print(check_pass(\"NoNumbers!!!!\"))      # False\n",
    "print(check_pass(\"NoSpecial123\"))       # False\n",
    "print(check_pass(\"Strong1!\"))           # True"
   ]
  },
