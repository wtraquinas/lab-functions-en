    "## 10. Write a function to check if a string is a pangram, i.e.: if it contains all the letters of the alphabet at least once. Mind that the strings may contain characters that are not letters."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 48,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n",
      "False\n",
      "True\n"
     ]
    }
   ],
   "source": [
    "def pangram(string):\n",
    "#your code here\n",
    "    alphabet = \"abcdefghijklmnopqrstuvwxyz\"\n",
    "    text_lower = string.lower()\n",
    "\n",
    "    for letter in alphabet:\n",
    "        if letter not in text_lower:\n",
    "            return False\n",
    "    return True\n",
    "\n",
    "\n",
    "print(pangram(\"The quick brown fox jumps over the lazy dog\"))   # True\n",
    "print(pangram(\"Hello, World!\"))                                  # False\n",
    "print(pangram(\"Pack my box with five dozen liquor jugs!\"))       # True"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 49,
