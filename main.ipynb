     "text": [
      "[1, 2, 3, 4, 5]\n",
      "['apple', 'banana', 'cherry']\n"
     ]
    }
   ],
   "source": [
    "def unique(lst_un):\n",
    "#your code here\n",
    "    un = []\n",
    "    for value in lst_un:\n",
    "        if value not in un:\n",
    "            un.append(value)\n",
    "    return un\n",
    "\n",
    "print(unique([1, 2, 2, 3, 4, 5, 5]))\n",
    "print(unique([\"apple\", \"banana\", \"cherry\", \"cherry\"]))"
