    "## 9. Write a function that calculates the standard deviation of a list.\n",
    "`NOTE: Do not use any libraries or already built functions. 😉`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "2.0"
      ]
     },
     "execution_count": 36,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def st_dev(list_sd):\n",
    "#your code here\n",
    "# Step 1: calculate the mean\n",
    "    mean = 0\n",
    "    for n in list_sd:\n",
    "        mean += n\n",
    "    mean = mean / len(list_sd)\n",
    "\n",
    "# Step 2: calculate the squared differences from the mean\n",
    "    squared_diffs = 0\n",
    "    for n in list_sd:\n",
    "        squared_diffs += (n - mean) ** 2\n",
    "\n",
    "# Step 3: divide by count and square root\n",
    "    variance = squared_diffs / len(list_sd)\n",
    "    std_dev = variance ** 0.5\n",
    "\n",
    "    return std_dev\n",
    "\n",
    "st_dev([2, 4, 4, 4, 5, 5, 7, 9])"
   ]
