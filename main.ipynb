    }
   ],
   "source": [
    "def oper_all(arr, oper = \"*\"):\n",
    "#your code here\n",
    "    if oper == \"+\":\n",
    "        return sum(arr)\n",
    "    else:\n",
    "        result = 1\n",
    "        for number in arr:\n",
    "            result *= number\n",
    "        return result\n",
    "    \n",
    "\n",
    "print(oper_all([5, 10, 15, 3], \"+\"))\n",
    "print(oper_all([5, 10, 15, 3]))"
